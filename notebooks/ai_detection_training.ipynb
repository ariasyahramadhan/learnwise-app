 "cells": [
  {
   "cell_type": "markdown",
   "id": "intro",
   "metadata": {},
   "source": [
    "# Model C — AI vs Human Text Detection (Deteksi Teks AI) — VERSI FINAL v1.0\n",
    "\n",
    "**Proyek:** LearnWise — Smart Academic Assessment System  \n",
    "**Deskripsi:** Notebook ini melatih model untuk mendeteksi apakah sebuah teks Bahasa Indonesia ditulis oleh manusia (*human-written*) atau dibuat oleh AI (*AI-generated* / ChatGPT / GPT-4). Model dilatih menggunakan TF-IDF Word & Char vectorizer serta fitur-fitur stylometry menggunakan klasifikasi `XGBoost`.\n",
    "\n",
    "---\n"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "step1",
   "metadata": {},
   "source": [
    "## Langkah 1 — Instalasi & Impor Library"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "code1",
   "metadata": {},
   "outputs": [],
   "source": [
    "!pip install xgboost scikit-learn pandas numpy joblib pyarrow --quiet\n",
    "\n",
    "import os\n",
    "import re\n",
    "import urllib.request\n",
    "import json\n",
    "import warnings\n",
    "import time\n",
    "import random\n",
    "import numpy as np\n",
    "import pandas as pd\n",
    "import joblib\n",
    "from xgboost import XGBClassifier\n",
    "from sklearn.feature_extraction.text import TfidfVectorizer\n",
    "from sklearn.metrics import classification_report, roc_auc_score, accuracy_score\n",
    "from sklearn.model_selection import train_test_split\n",
    "\n",
    "warnings.filterwarnings('ignore')\n",
    "print(\"Library berhasil di-import.\")"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "step2",
   "metadata": {},
   "source": [
    "## Langkah 2 — Mengunduh Dataset"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "code2",
   "metadata": {},
   "outputs": [],
   "source": [
    "ALPACA_URL = 'https://huggingface.co/api/datasets/FreedomIntelligence/alpaca-gpt4-indonesian/parquet/default/train/0.parquet'\n",
    "PAWS_URL = 'https://raw.githubusercontent.com/Wikidepia/indonesia_dataset/master/paraphrase/paws/data/final/train.tsv'\n",
    "\n",
    "print(\"Mengunduh Alpaca GPT-4 Indonesian...\")\n",
    "df_alpaca = pd.read_parquet(ALPACA_URL)\n",
    "print(f\"Alpaca dataset loaded: {len(df_alpaca):,} rows\")\n",
    "\n",
    "print(\"Mengunduh PAWS Indonesia...\")\n",
    "df_paws = pd.read_csv(PAWS_URL, sep='\\t')\n",
    "print(f\"PAWS dataset loaded: {len(df_paws):,} rows\")"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "step3",
   "metadata": {},
   "source": [
    "## Langkah 3 — Ekstraksi & Menyeimbangkan Panjang Kalimat"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "code3",
   "metadata": {},
   "outputs": [],
   "source": [
    "# Extract GPT-4 responses (AI)\n",
    "ai_texts = []\n",
    "for conv in df_alpaca['conversations']:\n",
    "    if len(conv) >= 2 and conv[1]['from'] == 'gpt':\n",
    "        ai_texts.append(conv[1]['value'])\n",
    "\n",
    "NUM_SAMPLES = 10000\n",
    "ai_texts = ai_texts[:NUM_SAMPLES]\n",
    "print(f\"Extracted {len(ai_texts):,} AI-generated texts (GPT-4)\")\n",
    "\n",
    "# Extract unique human sentences from PAWS\n",
    "human_sentences = list(pd.concat([df_paws['sentence1'], df_paws['sentence2']]).unique())\n",
    "random.seed(42)\n",
    "random.shuffle(human_sentences)\n",
    "print(f\"Extracted {len(human_sentences):,} unique human sentences from PAWS\")\n",
    "\n",
    "# Combine human sentences to match length distribution of AI texts\n",
    "ai_lengths = [len(t) for t in ai_texts]\n",
    "human_texts = []\n",
    "sent_idx = 0\n",
    "\n",
    "for target_len in ai_lengths:\n",
    "    para = []\n",
    "    curr_len = 0\n",
    "    while curr_len < target_len and sent_idx < len(human_sentences):\n",
    "        s = human_sentences[sent_idx]\n",
    "        para.append(s)\n",
    "        curr_len += len(s) + 1\n",
    "        sent_idx += 1\n",
    "    human_texts.append(\" \".join(para))\n",
    "    if sent_idx >= len(human_sentences):\n",
    "        break\n",
    "\n",
    "# Balance dataset sizes\n",
    "min_len = min(len(ai_texts), len(human_texts))\n",
    "ai_texts = ai_texts[:min_len]\n",
    "human_texts = human_texts[:min_len]\n",
    "\n",
    "df_ai = pd.DataFrame({'text': ai_texts, 'label': 1})\n",
    "df_human = pd.DataFrame({'text': human_texts, 'label': 0})\n",
    "df_dataset = pd.concat([df_ai, df_human], ignore_index=True)\n",
    "df_dataset = df_dataset.sample(frac=1, random_state=42).reset_index(drop=True)\n",
    "\n",
    "print(f\"Final dataset size: {len(df_dataset):,} rows\")"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "step4",
   "metadata": {},
   "source": [
    "## Langkah 4 — Ekstraksi Fitur Stylometry & Penanda ChatGPT"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "code4",
   "metadata": {},
   "outputs": [],
   "source": [
    "CHATGPT_MARKERS = [\n",
    "    r'\\boleh karena itu\\b',\n",
    "    r'\\bselain itu\\b',\n",
    "    r'\\bnamun\\b',\n",
    "    r'\\bsecara keseluruhan\\b',\n",
    "    r'\\bpenting untuk\\b',\n",
    "    r'\\bpada dasarnya\\b',\n",
    "    r'\\bdalam hal ini\\b',\n",
    "    r'\\bdengan demikian\\b',\n",
    "    r'\\bkesimpulannya\\b',\n",
    "    r'\\bsebagai contoh\\b'\n",
    "]\n",
    "\n",
    "def extract_stylometry(text):\n",
    "    text_str = str(text)\n",
    "    text_lower = text_str.lower()\n",
    "    words = text_str.split()\n",
    "    total_words = len(words)\n",
    "    total_chars = len(text_str)\n",
    "    \n",
    "    if total_words == 0:\n",
    "        return np.zeros(len(CHATGPT_MARKERS) + 7)\n",
    "    \n",
    "    # Lexical Diversity\n",
    "    unique_words = len(set(w.lower() for w in words))\n",
    "    ttr = unique_words / total_words\n",
    "    \n",
    "    # Word Length\n",
    "    word_lengths = [len(w) for w in words]\n",
    "    avg_word_len = sum(word_lengths) / total_words\n",
    "    \n",
    "    # Sentence Length\n",
    "    sentences = re.split(r'[.!?]+', text_str)\n",
    "    sentences = [s.strip() for s in sentences if s.strip()]\n",
    "    num_sentences = max(len(sentences), 1)\n",
    "    avg_sent_len = total_words / num_sentences\n",
    "    \n",
    "    # Punctuations\n",
    "    comma_rate = text_str.count(',') / max(total_chars, 1)\n",
    "    period_rate = text_str.count('.') / max(total_chars, 1)\n",
    "    question_rate = text_str.count('?') / max(total_chars, 1)\n",
    "    \n",
    "    cap_rate = sum(1 for c in text_str if c.isupper()) / max(total_chars, 1)\n",
    "    \n",
    "    # Transition word markers\n",
    "    marker_features = []\n",
    "    for marker in CHATGPT_MARKERS:\n",
    "        count = len(re.findall(marker, text_lower))\n",
    "        marker_features.append(count / total_words)\n",
    "        \n",
    "    return np.array([\n",
    "        ttr, avg_word_len, avg_sent_len, comma_rate, period_rate, question_rate, cap_rate\n",
    "    ] + marker_features)\n",
    "\n",
    "print(\"Mengekstrak fitur stylometry untuk dataset...\")\n",
    "sty_features = np.array([extract_stylometry(t) for t in df_dataset['text']])\n",
    "print(f\"Stylometric features shape: {sty_features.shape}\")"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "step5",
   "metadata": {},
   "source": [
    "## Langkah 5 — Vektorisasi TF-IDF Word & Char"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "code5",
   "metadata": {},
   "outputs": [],
   "source": [
    "def clean_text(text):\n",
    "    text = str(text).lower()\n",
    "    text = re.sub(r'[^\\w\\s]', ' ', text)\n",
    "    text = re.sub(r'\\s+', ' ', text).strip()\n",
    "    return text\n",
    "\n",
    "df_dataset['cleaned_text'] = df_dataset['text'].apply(clean_text)\n",
    "\n",
    "print(\"Melatih TF-IDF Word Vectorizer...\")\n",
    "word_vec = TfidfVectorizer(ngram_range=(1, 2), max_features=3000)\n",
    "X_word = word_vec.fit_transform(df_dataset['cleaned_text']).toarray()\n",
    "\n",
    "print(\"Melatih TF-IDF Char Vectorizer...\")\n",
    "char_vec = TfidfVectorizer(ngram_range=(3, 5), max_features=3000, analyzer='char')\n",
    "X_char = char_vec.fit_transform(df_dataset['cleaned_text']).toarray()\n",
    "\n",
    "# Combine all features\n",
    "X_combined = np.hstack([X_word, X_char, sty_features])\n",
    "y = df_dataset['label'].values\n",
    "print(f\"Combined features shape: {X_combined.shape}\")"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "step6",
   "metadata": {},
   "source": [
    "## Langkah 6 — Pelatihan Model XGBoost"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "code6",
   "metadata": {},
   "outputs": [],
   "source": [
    "X_train, X_test, y_train, y_test = train_test_split(X_combined, y, test_size=0.2, random_state=42, stratify=y)\n",
    "\n",
    "clf = XGBClassifier(\n",
    "    n_estimators=150,\n",
    "    max_depth=6,\n",
    "    learning_rate=0.1,\n",
    "    random_state=42,\n",
    "    use_label_encoder=False,\n",
    "    eval_metric='logloss'\n",
    ")\n",
    "\n",
    "print(\"Melatih XGBoost Classifier...\")\n",
    "clf.fit(X_train, y_train)\n",
    "print(\"Pelatihan selesai!\")"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "step7",
   "metadata": {},
   "source": [
    "## Langkah 7 — Evaluasi Model & Pencarian Threshold Optimal"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "code7",
   "metadata": {},
   "outputs": [],
   "source": [
    "y_pred = clf.predict(X_test)\n",
    "y_pred_proba = clf.predict_proba(X_test)[:, 1]\n",
    "\n",
    "print(f\"Accuracy: {accuracy_score(y_test, y_pred):.4f}\")\n",
    "print(f\"ROC-AUC: {roc_auc_score(y_test, y_pred_proba):.4f}\")\n",
    "print(\"\\nClassification Report:\")\n",
    "print(classification_report(y_test, y_pred, target_names=[\"Human\", \"AI\"]))\n",
    "\n",
    "# Find optimal threshold\n",
    "thresholds = np.linspace(0.1, 0.9, 81)\n",
    "best_f1 = 0\n",
    "best_thresh = 0.5\n",
    "for t in thresholds:\n",
    "    y_pred_t = (y_pred_proba >= t).astype(int)\n",
    "    from sklearn.metrics import f1_score\n",
    "    score = f1_score(y_test, y_pred_t)\n",
    "    if score > best_f1:\n",
    "        best_f1 = score\n",
    "        best_thresh = t\n",
    "\n",
    "print(f\"Optimal Threshold: {best_thresh:.4f} (Best F1-Score: {best_f1:.4f})\")"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "step8",
   "metadata": {},
   "source": [
    "## Langkah 8 — Menyimpan Artifacts Model"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "code8",
   "metadata": {},
   "outputs": [],
   "source": [
    "ARTIFACTS_DIR = os.path.join(\"..\", \"backend\", \"model_artifacts\", \"ai_detection\")\n",
    "os.makedirs(ARTIFACTS_DIR, exist_ok=True)\n",
    "\n",
    "joblib.dump(word_vec, os.path.join(ARTIFACTS_DIR, "ai_word_vectorizer.pkl"))\n",
    "joblib.dump(char_vec, os.path.join(ARTIFACTS_DIR, "ai_char_vectorizer.pkl"))\n",
    "joblib.dump(clf, os.path.join(ARTIFACTS_DIR, "ai_classifier.pkl"))\n",
    "\n",
    "config = {\n",
    "    \"threshold_optimal\": float(best_thresh),\n",
    "    \"accuracy\": float(accuracy_score(y_test, y_pred)),\n",
    "    \"auc\": float(roc_auc_score(y_test, y_pred_proba)),\n",
    "    \"features_stylometry_count\": int(sty_features.shape[1]),\n",
    "    \"features_word_count\": int(X_word.shape[1]),\n",
    "    \"features_char_count\": int(X_char.shape[1]),\n",
    "    \"chatgpt_markers\": CHATGPT_MARKERS\n",
    "}\n",
    "\n",
    "with open(os.path.join(ARTIFACTS_DIR, "ai_config.pkl"), "wb") as f:\n",
    "    joblib.dump(config, f)\n",
    "\n",
    "print(\"Model artifacts successfully saved!\")"
   ]
  }
